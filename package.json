{
  "name": "homepage-nav",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "db:create": "wrangler d1 create homepage-nav",
    "db:migrate:local": "wrangler d1 migrations apply homepage-nav --local",
    "db:migrate:remote": "wrangler d1 migrations apply homepage-nav --remote",
    "cf:setup": "node scripts/setup-cloudflare.mjs",
    "seed:generate": "node scripts/generate-seed.mjs"
  },
  "devDependencies": {
    "wrangler": "^4.24.3"
  }
}
